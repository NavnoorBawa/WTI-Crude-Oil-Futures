# Copy this file to ".env" and fill in your own API keys for local development.
# In CI (GitHub Actions) these are provided as repository Secrets instead.
# All keys are FREE-tier. The app degrades gracefully if any are missing
# (those data sources are simply skipped), but NEWSAPI_KEY powers the
# geopolitical-risk engine, so it is the most important one to set.

# https://newsapi.org  (geopolitical news + sentiment)  <-- most important
NEWSAPI_KEY=

# https://www.eia.gov/opendata/  (US crude oil inventories)
EIA_API_KEY=

# https://finnhub.io  (oil-sector equities)
FINNHUB_KEY=

# https://www.alphavantage.co  (supplementary market data)
ALPHA_VANTAGE_KEY=

# https://quickstats.nass.usda.gov/api  (corn/ethanol context)
USDA_NASS_KEY=

# https://www.ncdc.noaa.gov/cdo-web/token  (weather context)
NOAA_CDO_KEY=
